---
interface Props {
	title: string;
	description: string;
	locale?: 'en' | 'zh-cn';
	type?: 'website' | 'article';
	headline?: string;
	publishedAt?: Date;
}

const { title, description, locale = 'en', type = 'website', headline, publishedAt } = Astro.props;
const prefix = locale === 'zh-cn' ? '/zh-cn' : '';
const site = Astro.site ?? new URL(Astro.url.origin);
const englishPath = locale === 'zh-cn' ? Astro.url.pathname.replace(/^\/zh-cn/, '') || '/' : Astro.url.pathname;
const chinesePath = locale === 'zh-cn' ? Astro.url.pathname : `/zh-cn${Astro.url.pathname}`;
const englishUrl = new URL(englishPath, site);
const chineseUrl = new URL(chinesePath, site);
const alternate = locale === 'zh-cn' ? englishUrl.pathname : chineseUrl.pathname;
const canonical = locale === 'zh-cn' ? chineseUrl : englishUrl;
const image = new URL('/logo.png', site);
const pricingLabel = locale === 'zh-cn' ? '价格' : 'Pricing';
const organization = {
	'@type': 'Organization',
	'@id': new URL('/#organization', site).href,
	name: 'ZPan',
	url: new URL('/', site).href,
	logo: image.href,
	sameAs: ['https://github.com/saltbo/zpan', 'https://opencollective.com/zpan'],
};
const structuredData = Astro.url.pathname === '/' ? {
	'@context': 'https://schema.org',
	'@graph': [
		organization,
		{
			'@type': 'WebSite',
			'@id': new URL('/#website', site).href,
			name: 'ZPan',
			alternateName: 'zpan.space',
			url: new URL('/', site).href,
			publisher: { '@id': organization['@id'] },
		},
	],
} : type === 'article' ? {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: headline ?? title,
	description,
	datePublished: publishedAt?.toISOString(),
	inLanguage: locale === 'zh-cn' ? 'zh-CN' : 'en',
	mainEntityOfPage: canonical.href,
	author: { '@id': organization['@id'] },
	publisher: organization,
} : undefined;
const jsonLd = structuredData ? JSON.stringify(structuredData).replace(/</g, '\\u003c') : undefined;
---

<!doctype html>
<html lang={locale === 'zh-cn' ? 'zh-CN' : 'en'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="robots" content="index,follow,max-image-preview:large" />
		<meta name="theme-color" content="#f7faf9" />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" hreflang="en" href={englishUrl} />
		<link rel="alternate" hreflang="zh-CN" href={chineseUrl} />
		<link rel="alternate" hreflang="x-default" href={englishUrl} />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="ZPan" />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={locale === 'zh-cn' ? 'zh_CN' : 'en_US'} />
		<meta property="og:locale:alternate" content={locale === 'zh-cn' ? 'en_US' : 'zh_CN'} />
		<meta property="og:image" content={image} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1024" />
		<meta property="og:image:height" content="1024" />
		<meta property="og:image:alt" content="ZPan" />
		{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:image:alt" content="ZPan" />
		{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd}></script>}
		<title>{title}</title>
	</head>
		<body>
			<a class="skip-link" href="#main-content">{locale === 'zh-cn' ? '跳到正文' : 'Skip to Content'}</a>
		<header class="site-header">
			<div class="header-inner">
				<div class="header-left">
					<a class="brand" href={`${prefix}/`} aria-label="ZPan home">
						<img src="/logo.png" alt="" width="38" height="38" />
						<span>ZPan</span>
					</a>
					<nav class="desktop-primary-nav" aria-label="Main navigation">
						<a href={`${prefix}/pricing/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/pricing/`) ? 'page' : undefined}>{pricingLabel}</a>
						<a href={`${prefix}/docs/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/docs/`) ? 'page' : undefined}>{locale === 'zh-cn' ? '文档' : 'Docs'}</a>
						<a href={`${prefix}/blog/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/blog/`) ? 'page' : undefined}>Blog</a>
					</nav>
				</div>
			<div class="header-tools">
				<a class="drive-link" href="https://drive.zpan.space" target="_blank" rel="noopener noreferrer">Drive <span class="external-mark" aria-hidden="true">↗</span></a>
			<a class="language-switch" href={alternate} aria-label={locale === 'zh-cn' ? '切换到英文' : 'Switch to Chinese'}>
				<svg class="lang-icon" viewBox="-1.5 -1.5 27 27" fill="currentColor" aria-hidden="true" shape-rendering="geometricPrecision"><path d="M8.516 3a.94.94 0 0 0-.941.94v1.15H2.94a.94.94 0 1 0 0 1.882h7.362a7.422 7.422 0 0 1-1.787 3.958 7.42 7.42 0 0 1-1.422-2.425.94.94 0 1 0-1.774.627 9.303 9.303 0 0 0 1.785 3.043 7.422 7.422 0 0 1-4.164 1.278.94.94 0 1 0 0 1.881 9.303 9.303 0 0 0 5.575-1.855 9.303 9.303 0 0 0 4.11 1.74l-.763 1.525a.968.968 0 0 0-.016.034l-1.385 2.77a.94.94 0 1 0 1.683.841l1.133-2.267h5.806l1.134 2.267a.94.94 0 0 0 1.683-.841l-1.385-2.769a.95.95 0 0 0-.018-.036l-3.476-6.951a.94.94 0 0 0-1.682 0l-1.82 3.639a7.423 7.423 0 0 1-3.593-1.256 9.303 9.303 0 0 0 2.27-5.203h1.894a.94.94 0 0 0 0-1.881H9.456V3.94A.94.94 0 0 0 8.516 3Zm6.426 11.794a1.068 1.068 0 0 1-.02.039l-.703 1.407h3.924l-1.962-3.924-1.24 2.478Z" /></svg>
			</a>
				<a class="github-link" href="https://github.com/saltbo/zpan" target="_blank" rel="noopener noreferrer" aria-label="ZPan on GitHub">
					<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z" /></svg>
				</a>
			</div>
				<div class="mobile-actions">
					<details class="mobile-menu">
						<summary aria-label={locale === 'zh-cn' ? '打开导航菜单' : 'Open navigation menu'}>
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
						</summary>
						<div class="mobile-menu-panel">
							<nav aria-label="Mobile navigation">
								<a href={`${prefix}/pricing/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/pricing/`) ? 'page' : undefined}>{pricingLabel}</a>
								<a href={`${prefix}/docs/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/docs/`) ? 'page' : undefined}>{locale === 'zh-cn' ? '文档' : 'Docs'}</a>
								<a href={`${prefix}/blog/`} aria-current={Astro.url.pathname.startsWith(`${prefix}/blog/`) ? 'page' : undefined}>Blog</a>
								<a href="https://drive.zpan.space" target="_blank" rel="noopener noreferrer">Drive <span aria-hidden="true">↗</span></a>
								<a href="https://github.com/saltbo/zpan" target="_blank" rel="noopener noreferrer">GitHub <span aria-hidden="true">↗</span></a>
							</nav>
							<a class="mobile-language-switch" href={alternate}>
								<span>{locale === 'zh-cn' ? 'Language' : '语言'}</span>
								<strong>{locale === 'zh-cn' ? 'English' : '简体中文'}</strong>
							</a>
						</div>
					</details>
				</div>
			</div>
		</header>
			<main id="main-content">
			<slot />
		</main>
		<footer class="site-footer">
			<div>
				<a class="brand footer-brand" href={`${prefix}/`}><img src="/logo.png" alt="" width="34" height="34" /><span>ZPan</span></a>
				<p>{locale === 'zh-cn' ? '开源、S3 原生的文件托管平台。' : 'The open-source, S3-native file hosting platform.'}</p>
			</div>
			<div class="footer-links">
				<a href={`${prefix}/pricing/`}>{pricingLabel}</a>
				<a href={`${prefix}/docs/`}>{locale === 'zh-cn' ? '文档' : 'Documentation'}</a>
				<a href={`${prefix}/blog/`}>Blog</a>
				<a href="https://drive.zpan.space" target="_blank" rel="noopener noreferrer">Drive</a>
				<a href="https://cloud.zpan.space" target="_blank" rel="noopener noreferrer">Cloud</a>
				<a href="https://github.com/saltbo/zpan" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="https://opencollective.com/zpan" target="_blank" rel="noopener noreferrer">Open Collective</a>
			</div>
			<p class="copyright">© {new Date().getFullYear()} ZPan · AGPL-3.0</p>
		</footer>
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
