---
import MarketingLayout from '../layouts/MarketingLayout.astro';
interface Props { locale?: 'en' | 'zh-cn' }
const { locale = 'en' } = Astro.props;
const zh = locale === 'zh-cn';
const prefix = zh ? '/zh-cn' : '';
const tiers = zh ? [
	{ name: 'Community', label: '开源版', summary: '免费、自托管，适合个人、家庭和小团队。', features: ['文件管理、预览与搜索', '图床与自定义域名', '安全分享与 WebDAV', '个人空间与团队空间', '七种部署目标'], action: '开始部署', href: `${prefix}/docs/getting-started/prerequisites/` },
	{ name: 'Pro', label: '专业版', summary: '面向公开服务和专业运营者的控制能力。', features: ['Community 的全部功能', '开放注册与反滥用', '品牌与白标能力', '审计日志与更高限额', '云端许可证管理'], action: '购买 Pro', href: 'https://cloud.zpan.space', featured: true },
	{ name: 'Business', label: '商业版', summary: '面向需要配额、商业化和更复杂运营的团队。', features: ['Pro 的全部功能', '配额商品与充值卡', '积分与余额体系', '站内公告', '商业运营能力'], action: '获取商业版', href: 'https://cloud.zpan.space' },
] : [
	{ name: 'Community', label: 'OPEN SOURCE', summary: 'Free and self-hosted for individuals, families, and small teams.', features: ['File manager, previews, and search', 'Image hosting and custom domains', 'Secure sharing and WebDAV', 'Personal and team spaces', 'All seven deployment targets'], action: 'Start deploying', href: `${prefix}/docs/getting-started/prerequisites/` },
	{ name: 'Pro', label: 'FOR OPERATORS', summary: 'Controls for public services and professional operators.', features: ['Everything in Community', 'Open registration and anti-abuse', 'Branding and white label', 'Audit logs and higher limits', 'Cloud license management'], action: 'Get Pro', href: 'https://cloud.zpan.space', featured: true },
	{ name: 'Business', label: 'FOR COMMERCE', summary: 'For teams that need quotas, commerce, and deeper operations.', features: ['Everything in Pro', 'Quota products and gift cards', 'Credits and balance system', 'In-app announcements', 'Commercial operations'], action: 'Get Business', href: 'https://cloud.zpan.space' },
];
const rows = zh ? [
	['文件管理、图床、分享、WebDAV', '✓', '✓', '✓'], ['开源自托管', '✓', '✓', '✓'], ['开放注册与反滥用', '—', '✓', '✓'], ['白标与审计', '—', '✓', '✓'], ['配额与商业能力', '—', '—', '✓'],
] : [
	['File manager, image hosting, sharing, WebDAV', '✓', '✓', '✓'], ['Open-source self-hosting', '✓', '✓', '✓'], ['Open registration and anti-abuse', '—', '✓', '✓'], ['White label and audit', '—', '✓', '✓'], ['Quotas and commerce', '—', '—', '✓'],
];
---
<MarketingLayout title={zh ? '定价与版本 — ZPan' : 'Pricing & editions — ZPan'} description={zh ? '比较 ZPan Community、Pro 和 Business，选择适合你的部署方式。' : 'Compare ZPan Community, Pro, and Business and choose how you want to run it.'} locale={locale}>
	<section class="pricing-hero section-shell"><p class="eyebrow"><span></span>{zh ? '简单的版本划分' : 'Straightforward editions'}</p><h1>{zh ? '先拥有数据，再选择能力。' : 'Own your data. Choose the controls you need.'}</h1><p>{zh ? '核心文件能力始终可开源自托管。需要公开运营、品牌、审计或商业能力时，再升级到 Pro 或 Business。' : 'Core file capabilities remain open-source and self-hostable. Upgrade when you need public operations, branding, auditing, or commerce.'}</p></section>
	<section class="tier-grid section-shell">{tiers.map((tier) => <article class:list={['tier-card', { featured: tier.featured }]}><span class="tier-label">{tier.label}</span><h2>{tier.name}</h2><p class="tier-price">{tier.summary}</p><ul>{tier.features.map((feature) => <li>{feature}</li>)}</ul><a class:list={['button', tier.featured ? 'primary' : 'secondary']} href={tier.href}>{tier.action} {tier.href.startsWith('http') ? '↗' : '→'}</a></article>)}</section>
	<section class="managed-note section-shell"><div><h2>{zh ? '官方托管不是第四个版本。' : 'Managed hosting is not a fourth edition.'}</h2><p>{zh ? '它是一种交付方式：不想维护基础设施时，直接使用官方托管的 ZPan Drive；需要购买和管理 Pro 或 Business 许可证时，前往 ZPan Cloud。' : 'It is a delivery choice. Use the official ZPan Drive when you do not want to maintain infrastructure; use ZPan Cloud to buy and manage Pro or Business licenses.'}</p></div><div class="hero-actions"><a class="button primary" href="https://drive.zpan.space" target="_blank" rel="noopener noreferrer">{zh ? '打开云盘' : 'Open Drive'} ↗</a><a class="button secondary" href="https://cloud.zpan.space" target="_blank" rel="noopener noreferrer">ZPan Cloud ↗</a></div></section>
	<section class="comparison section-shell"><h2>{zh ? '版本对比' : 'Compare editions'}</h2><table class="comparison-table"><thead><tr><th>{zh ? '能力' : 'Capability'}</th><th>Community</th><th>Pro</th><th>Business</th></tr></thead><tbody>{rows.map((row) => <tr>{row.map((cell) => <td class:list={{ yes: cell === '✓' }}>{cell}</td>)}</tr>)}</tbody></table></section>
	<section class="faq section-shell"><h2>{zh ? '常见问题' : 'Questions, answered'}</h2><div class="faq-grid"><article><h3>{zh ? 'Community 会一直免费吗？' : 'Will Community remain free?'}</h3><p>{zh ? '会。Community 以 AGPL-3.0 发布，核心文件、图床、分享和 WebDAV 能力可自行部署。' : 'Yes. Community is released under AGPL-3.0 and keeps the core file, image hosting, sharing, and WebDAV workflows self-hostable.'}</p></article><article><h3>{zh ? '价格在哪里查看？' : 'Where can I see current prices?'}</h3><p>{zh ? 'Pro 与 Business 的最新价格、币种和购买周期以 ZPan Cloud 结算页面为准，官网不复制可能过期的数字。' : 'ZPan Cloud is the source of truth for current Pro and Business prices, currencies, and billing terms.'}</p></article><article><h3>{zh ? '付费版会托管我的文件吗？' : 'Do paid editions host my files?'}</h3><p>{zh ? '不会。购买许可证与存储位置是两件事。自托管时，文件仍在你选择的 S3 存储中。' : 'Not by itself. Licensing and file location are separate. With self-hosting, files stay in the S3 storage you choose.'}</p></article><article><h3>{zh ? '可以先体验再部署吗？' : 'Can I try ZPan before deploying?'}</h3><p>{zh ? '可以。打开 drive.zpan.space 使用官方托管版本，再决定是继续托管还是迁移到自己的部署。' : 'Yes. Open drive.zpan.space to use the official hosted version, then decide whether to stay managed or deploy your own.'}</p></article></div></section>
</MarketingLayout>
