---
import { getCollection } from 'astro:content';
import MarketingLayout from '../layouts/MarketingLayout.astro';

interface Props { locale?: 'en' | 'zh-cn' }
const { locale = 'en' } = Astro.props;
const zh = locale === 'zh-cn';
const prefix = zh ? '/zh-cn' : '';
const posts = (await getCollection('blog', ({ data }) => data.locale === locale && !data.draft))
	.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 3);
const slugFor = (id: string) => id.replace(`${locale}/`, '').replace(/\.(md|mdx)$/, '');

const copy = zh ? {
	title: 'ZPan — 把任意 S3 存储变成你的文件平台',
	description: '开源、S3 原生的文件托管平台。管理文件、搭建图床、安全分享，并部署在自己的基础设施上。',
	eyebrow: '开源 · S3 原生 · 可自托管',
	headline: '让你的 S3，真正好用起来。',
	intro: 'ZPan 为任意 S3 兼容存储提供现代文件管理、图床、分享、WebDAV 和远程下载。文件从浏览器直传存储，不消耗应用服务器带宽。',
	open: '打开官方云盘', deploy: '自行部署',
	proof: '一个应用，覆盖完整的文件工作流',
	workflowTitle: '不只是上传文件。',
	workflowIntro: '从日常文件管理到面向外部的分享与图片链接，ZPan 把常用能力放进一个干净、可控的平台。',
	archTitle: '文件走最短的路。',
	archText: 'ZPan 负责身份、权限、元数据和签名；客户端通过预签名 URL 直接与 S3 通信。更少的中转、更低的服务器成本，也没有存储厂商锁定。',
	deployTitle: '部署在你已经信任的基础设施上。',
	deployText: '首选 Cloudflare Workers + D1，也可用 Docker 或部署到 AWS、Vercel、Netlify、Azure 与 Google Cloud。',
	pricingTitle: '从个人使用，到经营一项服务。',
	pricingText: 'Community 永久开源；Pro 与 Business 为运营者提供品牌、审计、配额和商业能力。',
	blogTitle: 'ZPan 的最新进展',
	finalTitle: '先用起来，再决定如何部署。',
	finalText: '直接打开官方托管版本，或者用十分钟在自己的 Cloudflare 账户中启动 ZPan。',
} : {
	title: 'ZPan — Turn any S3 bucket into your file platform',
	description: 'The open-source, S3-native file platform for managing files, hosting images, sharing securely, and deploying on your infrastructure.',
	eyebrow: 'Open source · S3 native · Self-hostable',
	headline: 'Your S3, finally easy to use.',
	intro: 'ZPan adds a modern file manager, image hosting, secure sharing, WebDAV, and remote downloads to any S3-compatible storage. Files travel directly from the browser to your bucket.',
	open: 'Open hosted Drive', deploy: 'Deploy yourself',
	proof: 'One application for the whole file workflow',
	workflowTitle: 'More than a place to upload.',
	workflowIntro: 'From everyday file management to public links and image workflows, ZPan brings the essentials into one focused platform you control.',
	archTitle: 'Your files take the shortest route.',
	archText: 'ZPan handles identity, permissions, metadata, and signing. Clients then communicate directly with S3 through presigned URLs—less transit, lower server cost, and no storage lock-in.',
	deployTitle: 'Run it on infrastructure you already trust.',
	deployText: 'Cloudflare Workers with D1 is the primary target. Docker, AWS, Vercel, Netlify, Azure, and Google Cloud are supported too.',
	pricingTitle: 'From personal files to running a service.',
	pricingText: 'Community stays open source. Pro and Business add the controls operators need for branding, auditing, quotas, and commerce.',
	blogTitle: 'What is new in ZPan',
	finalTitle: 'Try it first. Choose how to run it later.',
	finalText: 'Open the official hosted drive now, or launch ZPan in your own Cloudflare account in about ten minutes.',
};

const workflows = zh ? [
	['文件云盘', '按文件夹管理图片、视频、音乐与文档，支持搜索、预览、回收站和团队空间。', '01'],
	['图床', '连接 PicGo、PicList、uPic、ShareX 或 API，在自己的域名下生成稳定图片链接。', '02'],
	['安全分享', '创建公开页或直链，并设置密码、有效期、下载次数与文件夹浏览。', '03'],
	['WebDAV 与远程下载', '挂载到现有客户端，或让服务端在后台把远程文件直接保存到存储。', '04'],
] : [
	['S3 web drive', 'Organize images, video, music, and documents with search, previews, trash, and team spaces.', '01'],
	['Image hosting', 'Connect PicGo, PicList, uPic, ShareX, or the API for durable image URLs on your domain.', '02'],
	['Secure sharing', 'Publish landing pages or direct links with passwords, expiration, download limits, and folder browsing.', '03'],
	['WebDAV & remote downloads', 'Mount ZPan in existing clients or let background workers save remote files straight to storage.', '04'],
];
---

<MarketingLayout title={copy.title} description={copy.description} locale={locale}>
	<section class="hero section-shell">
		<div class="hero-copy">
			<p class="eyebrow"><span></span>{copy.eyebrow}</p>
			<h1>{copy.headline}</h1>
			<p class="hero-intro">{copy.intro}</p>
			<div class="hero-actions">
				<a class="button primary" href="https://drive.zpan.space">{copy.open}<span>↗</span></a>
				<a class="button secondary" href={`${prefix}/docs/getting-started/choose-deployment/`}>{copy.deploy}<span>→</span></a>
			</div>
			<p class="hero-note">AGPL-3.0 · Cloudflare Workers · Docker · Any S3-compatible storage</p>
		</div>
		<div class="product-window" aria-label={zh ? 'ZPan 文件管理界面示意' : 'ZPan file manager preview'}>
			<div class="window-bar"><span></span><span></span><span></span><b>drive.zpan.space</b></div>
			<div class="app-shell">
				<aside class="app-sidebar">
					<div class="mini-brand"><img src="/logo.svg" alt="" />ZPan</div>
					<p>{zh ? '文件' : 'FILES'}</p>
					<div class="side-item active">▣ <span>{zh ? '我的文件' : 'My Files'}</span></div>
					<div class="side-item">▧ <span>{zh ? '图片' : 'Photos'}</span></div>
					<div class="side-item">▷ <span>{zh ? '视频' : 'Videos'}</span></div>
					<div class="side-item">↗ <span>{zh ? '我的分享' : 'Shares'}</span></div>
					<p>{zh ? '工具' : 'TOOLS'}</p>
					<div class="side-item">↓ <span>{zh ? '远程下载' : 'Remote downloads'}</span></div>
					<div class="side-item">◇ <span>{zh ? '图床' : 'Image hosting'}</span></div>
					<div class="storage-meter"><small>{zh ? '存储空间' : 'Storage'}</small><i><b></b></i><span>3.2 GB / 10 GB</span></div>
				</aside>
				<div class="file-panel">
					<div class="panel-head"><div><strong>{zh ? '我的文件' : 'My Files'}</strong><small>{zh ? '所有文件' : 'All files'}</small></div><div class="panel-actions"><span>⌕</span><button>＋ {zh ? '上传' : 'Upload'}</button></div></div>
					<div class="crumb">⌂ &nbsp;/&nbsp; design</div>
					<div class="file-table-head"><span>{zh ? '名称' : 'Name'}</span><span>{zh ? '大小' : 'Size'}</span><span>{zh ? '更新时间' : 'Updated'}</span></div>
					<div class="file-row"><i class="folder">◆</i><b>brand-assets</b><span>—</span><em>{zh ? '刚刚' : 'Just now'}</em></div>
					<div class="file-row"><i class="image">▧</i><b>launch-cover.png</b><span>1.8 MB</span><em>{zh ? '2 分钟前' : '2 min ago'}</em></div>
					<div class="file-row"><i class="doc">≡</i><b>release-notes.pdf</b><span>840 KB</span><em>{zh ? '昨天' : 'Yesterday'}</em></div>
					<div class="upload-toast"><span>✓</span><div><b>{zh ? '上传完成' : 'Upload complete'}</b><small>launch-cover.png</small></div></div>
				</div>
			</div>
		</div>
	</section>

	<section class="platform-strip section-shell">
		<p>{copy.proof}</p>
		<div><span>Cloudflare</span><span>Docker</span><span>Amazon S3</span><span>Cloudflare R2</span><span>Backblaze B2</span><span>Tigris</span></div>
	</section>

	<section class="features section-shell">
		<div class="section-heading"><div><p class="eyebrow"><span></span>{zh ? '核心工作流' : 'Core workflows'}</p><h2>{copy.workflowTitle}</h2></div><p>{copy.workflowIntro}</p></div>
		<div class="feature-grid">{workflows.map(([title, text, number]) => <article class="feature-card"><small>{number}</small><div class="feature-icon">{number === '01' ? '▣' : number === '02' ? '◇' : number === '03' ? '↗' : '↓'}</div><h3>{title}</h3><p>{text}</p></article>)}</div>
	</section>

	<section class="architecture section-shell">
		<div class="architecture-copy"><p class="eyebrow"><span></span>{zh ? 'S3 原生架构' : 'S3-native architecture'}</p><h2>{copy.archTitle}</h2><p>{copy.archText}</p><ul><li>{zh ? '浏览器直传 S3' : 'Browser-to-S3 uploads'}</li><li>{zh ? '不消耗服务端流量' : 'No server bandwidth relay'}</li><li>{zh ? '可迁移、无锁定' : 'Portable by design'}</li></ul></div>
		<div class="flow-diagram">
			<div class="flow-node client"><span>01</span><b>{zh ? '客户端' : 'Client'}</b><small>{zh ? '选择文件' : 'Select a file'}</small></div>
			<div class="flow-line"><i></i><small>{zh ? '请求签名' : 'Request signature'}</small></div>
			<div class="flow-node zpan"><img src="/logo.svg" alt="" /><b>ZPan</b><small>{zh ? '鉴权与签名' : 'Authorize & sign'}</small></div>
			<div class="flow-line direct"><i></i><small>{zh ? '直接上传' : 'Direct upload'}</small></div>
			<div class="flow-node storage"><span>03</span><b>S3</b><small>{zh ? '你的存储' : 'Your storage'}</small></div>
		</div>
	</section>

	<section class="deployment section-shell">
		<div><p class="eyebrow"><span></span>{zh ? '七种部署目标' : 'Seven deployment targets'}</p><h2>{copy.deployTitle}</h2><p>{copy.deployText}</p><a class="text-link" href={`${prefix}/docs/deployment/cloudflare/`}>{zh ? '查看部署文档' : 'Explore deployment guides'} →</a></div>
		<div class="deploy-list"><article class="featured"><small>{zh ? '首选' : 'PRIMARY'}</small><strong>Cloudflare Workers</strong><span>Workers · D1 · Zero server maintenance</span></article><article><small>{zh ? '自托管' : 'SELF-HOSTED'}</small><strong>Docker</strong><span>Node.js · SQLite · Your own server</span></article><p>AWS · Vercel · Netlify · Azure · Google Cloud</p></div>
	</section>

	<section class="pricing-preview section-shell">
		<div class="pricing-intro"><p class="eyebrow"><span></span>{zh ? '版本' : 'Editions'}</p><h2>{copy.pricingTitle}</h2><p>{copy.pricingText}</p><a class="text-link" href={`${prefix}/pricing/`}>{zh ? '比较全部版本' : 'Compare all editions'} →</a></div>
		<div class="edition-list"><article><small>COMMUNITY</small><strong>{zh ? '免费且开源' : 'Free & open source'}</strong><p>{zh ? '适合个人、家庭和小团队自行部署。' : 'For individuals, families, and small teams that self-host.'}</p><a href={`${prefix}/docs/getting-started/choose-deployment/`}>{zh ? '开始部署' : 'Start deploying'} →</a></article><article><small>PRO / BUSINESS</small><strong>{zh ? '面向专业运营' : 'Built for operators'}</strong><p>{zh ? '品牌、审计、配额、公告和商业能力。' : 'Branding, audit, quotas, announcements, and commerce.'}</p><a href="https://cloud.zpan.space">{zh ? '前往 ZPan Cloud' : 'Get it on ZPan Cloud'} ↗</a></article></div>
	</section>

	<section class="latest section-shell">
		<div class="latest-head"><div><p class="eyebrow"><span></span>Blog</p><h2>{copy.blogTitle}</h2></div><a class="text-link" href={`${prefix}/blog/`}>{zh ? '查看全部文章' : 'All articles'} →</a></div>
		<div class="latest-grid">{posts.map((post) => <article><div class="post-meta"><span>{post.data.tags[0]}</span><span>{post.data.publishedAt.getFullYear()}</span></div><h3><a href={`${prefix}/blog/${slugFor(post.id)}/`}>{post.data.title}</a></h3><p>{post.data.description}</p><a class="read-more" href={`${prefix}/blog/${slugFor(post.id)}/`}>{zh ? '阅读全文' : 'Read article'} →</a></article>)}</div>
	</section>

	<section class="final-cta section-shell"><p class="eyebrow"><span></span>{zh ? '开始使用' : 'Get started'}</p><h2>{copy.finalTitle}</h2><p>{copy.finalText}</p><div class="hero-actions"><a class="button primary" href="https://drive.zpan.space">{copy.open}<span>↗</span></a><a class="button secondary" href={`${prefix}/docs/getting-started/choose-deployment/`}>{copy.deploy}<span>→</span></a></div></section>
</MarketingLayout>
