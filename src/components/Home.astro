---
import MarketingLayout from '../layouts/MarketingLayout.astro';

interface Props { locale?: 'en' | 'zh-cn' }
const { locale = 'en' } = Astro.props;
const zh = locale === 'zh-cn';
const prefix = zh ? '/zh-cn' : '';

const copy = zh ? {
	title: 'ZPan — 云盘的选择，到 ZPan 为止',
	description: 'ZPan 是开源、S3 原生的云盘与文件管理平台，支持安全分享、图床、WebDAV、远程下载和自托管，数据可自由迁移。',
	eyebrow: '开源 · S3 原生 · 托管或自部署',
	headline: ['云盘的选择，', '到 ZPan 为止'],
	intro: 'Z 是最后一个字母。我们希望 ZPan 也是你的最后一个云盘选择：开放、可靠、可自由迁移，不靠锁定留住你，只让时间证明它值得一直用下去。',
	open: '打开 ZPan Drive', deploy: '部署 ZPan',
	workflowTitle: '管理、分享和使用你的文件。',
	workflowIntro: '一个应用覆盖日常文件管理和对外分享。图片、视频、文档与团队文件都使用一致的权限和存储模型。',
	archTitle: '文件直达存储，不必绕远路。',
	archText: 'ZPan 负责身份、权限、元数据和签名；上传与下载通过预签名 URL，直接在浏览器和 S3 存储之间完成。文件不经过应用服务器中转，存储始终独立、可迁移。',
} : {
	title: 'ZPan — Your search for a cloud drive ends here',
	description: 'ZPan is an open-source, S3-native cloud drive for file management, secure sharing, image hosting, WebDAV, remote downloads, and self-hosting.',
	eyebrow: 'Open source · S3 native · Hosted or self-hosted',
	headline: ['Your search for a', 'cloud drive ends with ZPan.'],
	intro: 'Z is the final letter. We want ZPan to be the final cloud drive you ever choose: open, dependable, and yours to move. It will never lock you in—it should earn its place for years to come.',
	open: 'Open ZPan Drive', deploy: 'Deploy ZPan',
	workflowTitle: 'Manage, share, and use your files.',
	workflowIntro: 'One application covers everyday file management and external sharing. Photos, videos, documents, and team files use one consistent permission and storage model.',
	archTitle: 'Files go straight to storage.',
	archText: 'ZPan handles identity, permissions, metadata, and signing. Uploads and downloads move directly between the browser and S3 through presigned URLs, keeping storage independent and portable.',
};

const productFeatures = zh ? [
	{ number: '01', icon: '▣', kicker: '文件管理', title: ['所有文件，', '一处管理。'], text: '图片、视频、音乐和文档统一放进 ZPan。使用文件夹、搜索、预览和回收站，让每个文件都清楚可见、随时可找。', points: ['文件夹与全局搜索', '图片、视频、音频与文档预览', '回收站与文件恢复'] },
	{ number: '02', icon: '↗', kicker: '安全分享', title: ['分享出去，', '控制权依然在你手里。'], text: '创建清晰的分享页或直接下载链接，并按场景设置访问边界。分享不是交出控制权，而是把文件安全地送到需要的人手中。', points: ['密码与有效期', '下载次数限制', '文件夹浏览权限'] },
	{ number: '03', icon: '◇', kicker: '图片托管', title: ['不只是存图片，', '更要让图片长期可用。'], text: '在自己的域名下生成稳定图片链接，并接入你已经习惯的上传工具。图片的存储位置、访问方式和域名都由你决定。', points: ['自定义图片域名', 'PicGo、PicList、uPic 与 ShareX', '开放上传 API'] },
	{ number: '04', icon: '⌁', kicker: 'WebDAV 与 API', title: ['不只在浏览器里使用。'], text: '通过 WebDAV 把 ZPan 挂载到系统和第三方客户端；通过 API Key 接入脚本、应用和自动化工作流。', points: ['Finder 与文件管理器', '兼容 WebDAV 客户端', 'API Key 与外部集成'] },
	{ number: '05', icon: '↓', kicker: '远程下载', title: ['把下载交给 ZPan。'], text: '提交远程地址后，下载节点在后台获取文件并保存到对象存储。关闭浏览器，任务仍会继续执行。', points: ['后台持续运行', '独立下载节点', '完成后自动入库'] },
	{ number: '06', icon: '◎', kicker: '个人与团队空间', title: ['个人文件与团队协作，', '各有边界。'], text: '个人空间保持私有；团队空间拥有独立的成员、角色、文件和配额。一个 ZPan，同时服务个人与团队。', points: ['独立个人空间', '团队成员与角色', '分离的文件和配额'] },
] : [
	{ number: '01', icon: '▣', kicker: 'File management', title: ['Every file,', 'managed in one place.'], text: 'Keep photos, videos, music, and documents together in ZPan. Folders, search, previews, and trash keep every file visible and easy to find.', points: ['Folders and global search', 'Image, video, audio, and document previews', 'Trash and file recovery'] },
	{ number: '02', icon: '↗', kicker: 'Secure sharing', title: ['Share files without', 'giving up control.'], text: 'Create clear sharing pages or direct download links, then define the right access boundary for each situation.', points: ['Passwords and expiration', 'Download limits', 'Folder browsing permissions'] },
	{ number: '03', icon: '◇', kicker: 'Image hosting', title: ['Store images and keep', 'their links dependable.'], text: 'Create stable image URLs on your own domain and connect the upload tools you already use. You control storage, access, and naming.', points: ['Custom image domains', 'PicGo, PicList, uPic, and ShareX', 'Open upload API'] },
	{ number: '04', icon: '⌁', kicker: 'WebDAV & API', title: ['Use ZPan beyond', 'the browser.'], text: 'Mount ZPan in system and third-party clients through WebDAV, or connect scripts, applications, and automation with API keys.', points: ['Finder and file managers', 'Compatible WebDAV clients', 'API keys and integrations'] },
	{ number: '05', icon: '↓', kicker: 'Remote downloads', title: ['Let ZPan handle', 'the download.'], text: 'Submit a remote URL and a download node fetches the file in the background before saving it to object storage.', points: ['Runs in the background', 'Independent download nodes', 'Automatic storage import'] },
	{ number: '06', icon: '◎', kicker: 'Personal & team spaces', title: ['Keep personal files', 'and teamwork separate.'], text: 'Personal spaces stay private. Team spaces have independent members, roles, files, and quotas. One ZPan serves both.', points: ['Private personal spaces', 'Team members and roles', 'Separate files and quotas'] },
];

const platforms = [
	['Cloudflare Workers', 'https://cdn.simpleicons.org/cloudflare/F38020'],
	['Docker', 'https://cdn.simpleicons.org/docker/2496ED'],
	['AWS', 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg'],
	['Vercel', 'https://cdn.simpleicons.org/vercel/000000'],
	['Netlify', 'https://cdn.simpleicons.org/netlify/00C7B7'],
	['Microsoft Azure', 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/azure/azure-original.svg'],
	['Google Cloud', 'https://cdn.simpleicons.org/googlecloud/4285F4'],
];
---

<MarketingLayout title={copy.title} description={copy.description} locale={locale}>
	<section class="hero section-shell">
		<div class="hero-copy">
			<p class="eyebrow"><span></span>{copy.eyebrow}</p>
			<h1>{copy.headline.map((line) => <span class="heading-line">{line}</span>)}</h1>
			<p class="hero-intro">{copy.intro}</p>
			<div class="hero-actions">
				<a class="button primary" href="https://drive.zpan.space" target="_blank" rel="noopener noreferrer">{copy.open}<span aria-hidden="true">↗</span></a>
				<a class="button secondary" href="#self-host">{copy.deploy}<span aria-hidden="true">↓</span></a>
			</div>
			<p class="hero-note">{zh ? '官方托管可直接使用 · AGPL-3.0 · 支持任意 S3 兼容存储' : 'Official hosting available · AGPL-3.0 · Any S3-compatible storage'}</p>
		</div>
		<div class="product-window" role="img" aria-label={zh ? 'ZPan 文件管理界面示意' : 'ZPan file manager preview'}>
			<div class="window-bar"><span></span><span></span><span></span><b>drive.zpan.space</b></div>
			<div class="app-shell">
				<aside class="app-sidebar">
					<div class="mini-brand"><img src="/logo.png" alt="" width="21" height="21" />ZPan</div>
					<p>{zh ? '文件' : 'FILES'}</p>
					<div class="side-item active">▣ <span>{zh ? '我的文件' : 'My Files'}</span></div>
					<div class="side-item">▧ <span>{zh ? '图片' : 'Photos'}</span></div>
					<div class="side-item">▷ <span>{zh ? '视频' : 'Videos'}</span></div>
					<div class="side-item">↗ <span>{zh ? '我的分享' : 'Shares'}</span></div>
					<p>{zh ? '工具' : 'TOOLS'}</p>
					<div class="side-item">↓ <span>{zh ? '远程下载' : 'Remote downloads'}</span></div>
					<div class="side-item">◇ <span>{zh ? '图床' : 'Image hosting'}</span></div>
					<div class="storage-meter"><small>{zh ? '存储空间' : 'Storage'}</small><i><b></b></i><span>3.2 GB / 10 GB</span></div>
				</aside>
				<div class="file-panel">
					<div class="panel-head"><div><strong>{zh ? '我的文件' : 'My Files'}</strong><small>{zh ? '所有文件' : 'All files'}</small></div><div class="panel-actions"><span aria-hidden="true">⌕</span><span class="preview-upload">＋ {zh ? '上传' : 'Upload'}</span></div></div>
					<div class="crumb">⌂ &nbsp;/&nbsp; design</div>
					<div class="file-table-head"><span>{zh ? '名称' : 'Name'}</span><span>{zh ? '大小' : 'Size'}</span><span>{zh ? '更新时间' : 'Updated'}</span></div>
					<div class="file-row"><i class="folder">◆</i><b>brand-assets</b><span>—</span><em>{zh ? '刚刚' : 'Just now'}</em></div>
					<div class="file-row"><i class="image">▧</i><b>launch-cover.png</b><span>1.8 MB</span><em>{zh ? '2 分钟前' : '2 min ago'}</em></div>
					<div class="file-row"><i class="doc">≡</i><b>release-notes.pdf</b><span>840 KB</span><em>{zh ? '昨天' : 'Yesterday'}</em></div>
					<div class="upload-toast"><span>✓</span><div><b>{zh ? '上传完成' : 'Upload complete'}</b><small>launch-cover.png</small></div></div>
				</div>
			</div>
		</div>
	</section>

	<section class="architecture section-shell">
		<div class="architecture-copy"><p class="eyebrow"><span></span>{zh ? 'S3 原生架构' : 'S3-native architecture'}</p><h2>{copy.archTitle}</h2><p>{copy.archText}</p><ul><li>{zh ? '浏览器直传 S3' : 'Browser-to-S3 uploads'}</li><li>{zh ? '不消耗服务端流量' : 'No server bandwidth relay'}</li><li>{zh ? '可迁移、无锁定' : 'Portable by design'}</li></ul></div>
		<div class="architecture-diagram">
			<svg viewBox="0 0 700 420" role="img" aria-labelledby="architecture-title architecture-description">
				<title id="architecture-title">ZPan direct-to-S3 architecture</title>
				<desc id="architecture-description">The browser exchanges control requests and presigned URLs with ZPan, while file bytes move directly between the browser and S3-compatible object storage. ZPan stores metadata in its database.</desc>
				<defs>
					<marker id="arrow-control" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" /></marker>
					<marker id="arrow-data" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M 0 0 L 10 5 L 0 10 z" /></marker>
				</defs>

				<text class="diagram-kicker" x="35" y="34">CONTROL PLANE + DIRECT DATA PATH</text>

				<path class="control-path" d="M 202 102 L 266 102" marker-end="url(#arrow-control)" />
				<path class="control-path" d="M 266 145 L 202 145" marker-end="url(#arrow-control)" />
				<text class="path-label" x="234" y="88" text-anchor="middle">REQUEST</text>
				<text class="path-label" x="234" y="169" text-anchor="middle">PRESIGNED URL</text>

				<path class="metadata-path" d="M 356 184 L 356 223" marker-end="url(#arrow-control)" />
				<text class="path-label" x="371" y="210">METADATA</text>

				<path class="data-path" d="M 117 183 C 117 374, 396 399, 501 319" marker-start="url(#arrow-data)" marker-end="url(#arrow-data)" />
				<g class="data-label" transform="translate(193 344)">
					<rect width="188" height="32" rx="16" />
					<text x="94" y="20" text-anchor="middle">DIRECT FILE TRANSFER</text>
				</g>

				<g class="diagram-node client-node">
					<rect x="34" y="63" width="168" height="120" rx="14" />
					<circle cx="58" cy="87" r="6" />
					<text class="node-kind" x="76" y="91">CLIENT</text>
					<text class="node-title" x="58" y="131">Web browser</text>
					<text class="node-detail" x="58" y="155">UI · uploads · downloads</text>
				</g>

				<g class="diagram-node zpan-node">
					<rect x="266" y="47" width="180" height="137" rx="14" />
					<image href="/logo.png" x="280" y="62" width="26" height="26" />
					<text class="node-kind" x="316" y="78">CONTROL PLANE</text>
					<text class="node-title" x="290" y="122">ZPan</text>
					<text class="node-detail" x="290" y="148">Auth · policy · signing</text>
				</g>

				<g class="diagram-node database-node">
					<rect x="281" y="223" width="150" height="83" rx="12" />
					<text class="node-kind" x="302" y="250">DATABASE</text>
					<text class="node-title small" x="302" y="276">Metadata only</text>
					<text class="node-detail" x="302" y="294">No file bytes</text>
				</g>

				<g class="diagram-node storage-node">
					<rect x="501" y="257" width="165" height="120" rx="14" />
					<circle cx="526" cy="282" r="6" />
					<text class="node-kind" x="544" y="286">DATA PLANE</text>
					<text class="node-title" x="525" y="326">S3 storage</text>
					<text class="node-detail" x="525" y="350">R2 · S3 · B2 · MinIO</text>
				</g>
			</svg>
		</div>
	</section>

	<section class="platform-marquee" aria-labelledby="platform-heading">
		<div class="platform-marquee-head section-shell"><p class="eyebrow"><span></span>{zh ? '多平台部署' : 'Deploy anywhere'}</p><h2 id="platform-heading">{zh ? '运行在你选择的基础设施上。' : 'Run on the infrastructure you choose.'}</h2></div>
		<div class="platform-track-mask">
			<div class="platform-track">{[...platforms, ...platforms].map(([name, icon], index) => <div class="platform-item" aria-hidden={index >= platforms.length ? 'true' : undefined}><img src={icon} alt="" width="25" height="25" loading="lazy" /><span>{name}</span></div>)}</div>
		</div>
	</section>

	<section class="product-story section-shell" aria-labelledby="product-features-heading">
		<header class="product-story-head"><p class="eyebrow"><span></span>{zh ? '产品功能' : 'Product features'}</p><h2 id="product-features-heading">{copy.workflowTitle}</h2><p>{copy.workflowIntro}</p></header>
		<div class="product-feature-list">{productFeatures.map((feature, index) => <article class:list={['product-feature', { reverse: index % 2 === 1 }]}>
			<div class="product-feature-copy"><div class="feature-kicker"><span>{feature.number}</span>{feature.kicker}</div><h3>{feature.title.map((line) => <span class="heading-line">{line}</span>)}</h3><p>{feature.text}</p><ul>{feature.points.map((point) => <li>{point}</li>)}</ul></div>
			<div class="product-feature-visual" aria-hidden="true"><div class="visual-toolbar"><span></span><span></span><span></span><small>ZPAN / {feature.kicker.toUpperCase()}</small></div><div class="visual-feature-mark">{feature.icon}</div><strong>{feature.kicker}</strong><div class="visual-feature-rows">{feature.points.map((point, pointIndex) => <div><span>{String(pointIndex + 1).padStart(2, '0')}</span><b>{point}</b><i>✓</i></div>)}</div></div>
		</article>)}</div>
	</section>

	<section class="final-cta self-host-cta section-shell" id="self-host"><p class="eyebrow"><span></span>{zh ? '自托管 ZPan' : 'Self-host ZPan'}</p><h2>{zh ? '最后的选择，也可以完全属于你。' : 'Your final choice can belong entirely to you.'}</h2><p>{zh ? 'ZPan Community 开源且免费。把完整的 ZPan 部署到自己的基础设施，连接自己的 S3 存储，让应用、数据库、文件和域名都由自己掌控。需要品牌、审计、公开运营或商业能力时，再升级到 Pro 或 Business。' : 'ZPan Community is open source and free. Run the complete platform on your infrastructure, connect your own S3 storage, and control the app, database, files, and domain. Upgrade to Pro or Business only when you need branding, auditing, public operations, or commerce.'}</p><div class="hero-actions"><a class="button primary" href={`${prefix}/pricing/`}>{zh ? '查看自托管方案' : 'Explore Self-hosting'} <span aria-hidden="true">→</span></a><a class="button secondary" href={`${prefix}/docs/getting-started/prerequisites/`}>{zh ? '阅读部署文档' : 'Read Deployment Docs'} <span aria-hidden="true">→</span></a></div></section>
</MarketingLayout>
